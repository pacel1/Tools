{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "convertbase.app" }],
      "destination": "https://www.convertbase.app/en",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "convertbase.app" }],
      "destination": "https://www.convertbase.app/$1",
      "permanent": true
    }
  ]
}
